# ============================================
# BACKEND ENV TEMPLATE (safe to commit)
# ============================================

# Database (choose one in deployment)
# LOCAL:
# BD_CONEXION=Driver={ODBC Driver 17 for SQL Server};Server=TU_SERVIDOR_LOCAL;DATABASE=TU_DB_LOCAL;Trusted_Connection=yes;

# PROD (Azure SQL):
AZURE_SQL_CONNECTIONSTRING=Driver={ODBC Driver 17 for SQL Server};Server=tcp:your-server.database.windows.net,1433;Database=your-db;Uid=your-user;Pwd=your-password;Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30;

# JWT
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRATION_HOURS=24

# CORS
FRONTEND_URL=https://your-app.vercel.app
ALLOW_VERCEL_PREVIEWS=false

# Email
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@example.com
SENDER_PASSWORD=replace-with-app-password
ADMIN_EMAIL=admin@example.com

# Uploads
UPLOAD_FOLDER=app/static/uploads
MAX_CONTENT_LENGTH=5242880
