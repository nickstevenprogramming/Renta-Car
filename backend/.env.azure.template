# Azure App Service Environment Variables Template
# Copy this to Azure App Service > Configuration > Application settings

# Database - Azure SQL Connection String
# Get this from Azure Portal > SQL Database > Connection strings
AZURE_SQL_CONNECTIONSTRING=Driver={ODBC Driver 17 for SQL Server};Server=tcp:your-server.database.windows.net,1433;Database=your-db;Uid=your-user;Pwd=your-password;Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30;

# JWT Secret - Generate a secure random string
# Use: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-secure-random-secret-here

# Frontend URL for CORS (your Vercel deployment URL)
FRONTEND_URL=https://your-app.vercel.app
ALLOW_VERCEL_PREVIEWS=false

# Email Configuration (optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password
ADMIN_EMAIL=admin@your-domain.com
